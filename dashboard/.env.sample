# Copy to .env and fill in real values. .env is gitignored; never commit it.

# Database connection (defaults for src/lib/settings.ts; the Settings page
# can override these at runtime via data/settings.json)
HX_DB_HOST=127.0.0.1
HX_DB_PORT=3306
HX_DB_NAME=hx_trades
HX_DB_USER=hx
HX_DB_PASSWORD=

# Optional X-Api-Key required on POST /api/import (empty = no auth)
HX_API_KEY=

# Dashboard login (/login page, session cookie enforced by src/middleware.ts)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=admin
